# List builtins: range, reverse, take, drop, append (concat), sum, min, max
fn | check ( str | name, str | got, str | want ) > {
  if got == want {
    out(name + ": OK")
  } else {
    out(name + ": FAIL got \"" + got + "\" want \"" + want + "\"")
  }
}

out("--- List builtins ---")
list: r = range(0, 5)
check("range", join(r, ","), "0,1,2,3,4")

list: a = [1, 2, 3, 4, 5]
list: reversed = reverse(a)
check("reverse", reversed[0] + "", "5")
check("reverse-len", len(reversed) + "", "5")

list: taken = take(a, 2)
check("take", len(taken) + "", "2")
check("take-first", taken[0] + "", "1")

list: dropped = drop(a, 2)
check("drop", len(dropped) + "", "3")
check("drop-first", dropped[0] + "", "3")

list: b = [10, 20]
list: cat = append(a, b)
check("append", len(cat) + "", "7")
check("append-last", cat[6] + "", "20")

check("sum", sum(a) + "", "15")
check("min", min(1, 2, 3, 4, 5) + "", "1")
check("max", max(1, 2, 3, 4, 5) + "", "5")
